<UserControl
    x:Class="ShadeFlow.Controls.PropertiesControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ShadeFlow.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Padding="10,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock 
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="着色器属性" />
                
            <TextBlock 
                Grid.Column="1"
                x:Name="SelectedShaderName"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="(未选择)"
                Margin="0,0,12,0" />
        </Grid>

        <!-- 属性列表 -->
        <ScrollViewer Grid.Row="1" Padding="8,8,8,8">
            <StackPanel>
                <TextBlock 
                    x:Name="NoSelectionText"
                    Text="选择一个节点来编辑其属性"
                    FontSize="14"
                    Opacity="0.5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20"
                    TextWrapping="Wrap"
                    Visibility="Visible" />
                    
                <StackPanel x:Name="PropertyEditorPanel" Visibility="Collapsed">
                    <TextBlock Text="常量" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <StackPanel x:Name="ConstantsPanel">
                        <!-- 这里将动态填充常量编辑器 -->
                    </StackPanel>
                    
                    <TextBlock Text="输入" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,12" />

                    <StackPanel x:Name="InputsPanel">
                        <!-- 这里将动态填充输入编辑器 -->
                    </StackPanel>
                    
                    <TextBlock Text="输出" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,12" />

                    <StackPanel x:Name="OutputsPanel">
                        <!-- 这里将动态填充输出编辑器 -->
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>