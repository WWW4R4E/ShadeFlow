<UserControl
    x:Class="ShadeFlow.Controls.SceneTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2006/xaml/presentation"
    xmlns:local="using:ShadeFlow.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ShadeFlow.Models"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource CardBackgroundFillColorDefault}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  标题栏  -->
        <Grid Grid.Row="0" Padding="10,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="场景树" />

            <Button
                x:Name="CollapseAllButton"
                Grid.Column="1"
                Width="24"
                Height="24"
                Margin="0,0,8,0"
                Background="Transparent"
                BorderThickness="0"
                Click="CollapseAllButton_Click"
                Content="−"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <!--  场景树  -->
        <TreeView
            x:Name="SceneTreeView"
            Grid.Row="1"
            Margin="6,8,6,8"
            AllowDrop="True"
            CanDragItems="True"
            CanReorderItems="True"
            RightTapped="SceneTreeView_RightTapped">
            <TreeView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutSubItem x:Name="AddNodeMenuItem" Text="添加节点">
                        <MenuFlyoutSubItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="N" Modifiers="Control" />
                        </MenuFlyoutSubItem.KeyboardAccelerators>
                        <MenuFlyoutItem Text="立方体" Click="AddCubeMenuItem_Click" />
                        <MenuFlyoutItem Text="球体" Click="AddSphereMenuItem_Click" />
                        <MenuFlyoutItem Text="圆柱体" Click="AddCylinderMenuItem_Click" />
                        <MenuFlyoutItem Text="圆锥体" Click="AddConeMenuItem_Click" />
                    </MenuFlyoutSubItem>
                    <MenuFlyoutItem x:Name="DeleteNodeMenuItem" Text="删除节点" Click="DeleteNodeMenuItem_Click">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Delete" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="RenameNodeMenuItem" Text="重命名" Click="RenameNodeMenuItem_Click">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F2" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="DuplicateNodeMenuItem" Text="复制节点" Click="DuplicateNodeMenuItem_Click">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="C" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </TreeView.ContextFlyout>
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="models:TreeViewItemModel">
                    <TreeViewItem IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}" ItemsSource="{x:Bind Children, Mode=OneWay}" >
                        <TreeViewItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="Delete" Invoked="TreeViewItem_DeleteAccelerator_Invoked" />
                            <KeyboardAccelerator Key="F2" Invoked="TreeViewItem_RenameAccelerator_Invoked" />
                            <KeyboardAccelerator Key="D" Modifiers="Control" Invoked="TreeViewItem_DuplicateAccelerator_Invoked" />
                        </TreeViewItem.KeyboardAccelerators>
                        <StackPanel Orientation="Horizontal">
                            <FontIcon
                                Margin="0,0,6,0"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="{x:Bind Icon, Mode=OneWay}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="{x:Bind Name, Mode=OneWay}" />
                        </StackPanel>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>