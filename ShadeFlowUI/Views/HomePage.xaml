<Page
    x:Class="ShadeFlow.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ShadeFlow.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ShadeFlow.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:ShadeFlow.ViewModels"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="350" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="CenterColumn" Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="RightColumn" Width="350" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="FilePanel" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:SceneTreeControl Grid.Row="0" />

                <Grid Grid.Row="1" Background="{ThemeResource CardStrokeColorDefault}">
                    <Border
                        x:Name="HorizontalVisualLine2"
                        Width="120"
                        Height="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="5" />
                </Grid>

                <controls:ExplorerControl x:Name="explorerControl" Grid.Row="2" />
            </Grid>

            <Grid
                Grid.Column="1"
                HorizontalAlignment="Center"
                Background="{ThemeResource CardStrokeColorDefault}">
                <Border
                    x:Name="VerticalVisualLine1"
                    Width="6"
                    Height="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource TextFillColorTertiaryBrush}"
                    CornerRadius="5" />
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TopRow" Height="*" />
                    <RowDefinition Height="25" />
                    <RowDefinition x:Name="BottomRow" Height="*" />
                </Grid.RowDefinitions>


                <controls:SwapChainControl
                    x:Name="renderPreview"
                    Grid.Row="0"
                    BorderBrush="{ThemeResource ButtonBackground}"
                    BorderThickness="1"
                    CleanupRendererCommand="{x:Bind ViewModel.CleanupCommand, Mode=OneWay}"
                    InitializeRendererCommand="{x:Bind ViewModel.InitializeRendererCommand, Mode=OneWay}"
                    ResizeRendererCommand="{x:Bind ViewModel.ResizeRendererCommand, Mode=OneWay}" />

                <Grid
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardStrokeColorDefault}">
                    <Border
                        x:Name="HorizontalVisualLine"
                        Width="120"
                        Height="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="5" />
                </Grid>

                <controls:NodeEditor
                    x:Name="nodeEditor"
                    Grid.Row="2"
                    ItemsSource="{x:Bind ViewModel.Nodes}" />
            </Grid>

            <Grid
                x:Name="HorizontalHoverZone"
                Grid.Column="2"
                Width="250"
                Height="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="Transparent"
                PointerEntered="HorizontalHoverZone_PointerEntered"
                PointerExited="HorizontalHoverZone_PointerExited"
                PointerMoved="HorizontalHoverZone_PointerMoved_Drag"
                PointerPressed="HorizontalHoverZone_PointerPressed"
                PointerReleased="HorizontalHoverZone_PointerReleased" />

            <Grid
                Grid.Column="3"
                HorizontalAlignment="Left"
                Background="{ThemeResource CardStrokeColorDefault}">
                <Border
                    x:Name="VerticalVisualLine2"
                    Width="6"
                    Height="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource TextFillColorTertiaryBrush}"
                    CornerRadius="5" />
            </Grid>

            <Grid
                x:Name="propertyPanel"
                Grid.Column="4"
                Background="{ThemeResource CardBackgroundFillColorDefault}">
                <controls:PropertiesControl />
            </Grid>
        </Grid>

        <Grid
            x:Name="VerticalHoverZone1"
            Width="25"
            Height="250"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Transparent"
            PointerEntered="VerticalHoverZone1_PointerEntered"
            PointerExited="VerticalHoverZone1_PointerExited"
            PointerMoved="VerticalHoverZone1_PointerMoved_Drag"
            PointerPressed="VerticalHoverZone1_PointerPressed"
            PointerReleased="VerticalHoverZone1_PointerReleased" />

        <Grid
            x:Name="VerticalHoverZone2"
            Width="25"
            Height="250"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="Transparent"
            PointerEntered="VerticalHoverZone2_PointerEntered"
            PointerExited="VerticalHoverZone2_PointerExited"
            PointerMoved="VerticalHoverZone2_PointerMoved_Drag"
            PointerPressed="VerticalHoverZone2_PointerPressed"
            PointerReleased="VerticalHoverZone2_PointerReleased" />

    </Grid>
</Page>