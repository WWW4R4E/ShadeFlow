<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ShadeFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ShadeFlow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ShadeFlow.Views"
    Title="ShadeFlow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Grid.Resources>
            <Style x:Key="TitleBarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="48"/>
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontSize" Value="12" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar">
            <TitleBar.LeftHeader>
                <StackPanel Orientation="Horizontal">
                    <ImageIcon
                        Width="18"
                        Height="18"
                        Margin="12,0,0,0"
                        Source="Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="ShadeFlow" />
                    <MenuBar>
                        <MenuBarItem Title="文件">
                            <MenuFlyoutItem Text="打开..." Click="Open_Click"/>
                            <MenuFlyoutItem Text="新建窗口" Click="NewWindow_Click"/>
                            <MenuFlyoutItem Text="退出" Click="Exit_Click"/>
                        </MenuBarItem>

                        <MenuBarItem Title="视图">
                            <MenuFlyoutItem Text="主侧边栏" Click="MainSidebar_Click"/>
                            <MenuFlyoutItem Text="辅助侧边栏" Click="SecondarySidebar_Click"/>
                            <MenuFlyoutItem Text="状态栏" Click="StatusBar_Click"/>
                        </MenuBarItem>

                        <MenuBarItem Title="帮助">
                            <MenuFlyoutItem Text="关于" Click="About_Click"/>
                            <MenuFlyoutItem Text="反馈" Click="Feedback_Click"/>
                        </MenuBarItem>
                    </MenuBar>
                </StackPanel>
            </TitleBar.LeftHeader>
            <TitleBar.RightHeader>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,160,0" >
                    <StackPanel.RenderTransform>
                        <TranslateTransform X="280" />
                    </StackPanel.RenderTransform>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Click="MainSidebar_Click" ToolTipService.ToolTip="主侧边栏">
                        <SymbolIcon Symbol="DockLeft" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Click="StatusBar_Click" ToolTipService.ToolTip="状态栏">
                        <SymbolIcon Symbol="DockBottom" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Click="SecondarySidebar_Click" ToolTipService.ToolTip="辅助侧边栏">
                        <SymbolIcon Symbol="DockRight" />
                    </Button>
                </StackPanel>
            </TitleBar.RightHeader>
        </TitleBar>

        <views:HomePage Grid.Row="1" />
    </Grid>

</Window>